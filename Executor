-- User Modifiable Script Database
local savedScripts = {}

-- Safe Local Database Handlers
local function loadScriptsData()
    if isfile and readfile and isfile(FILE_NAME) then
        local success, decoded = pcall(function()
            return HttpService:JSONDecode(readfile(FILE_NAME))
        end)
        if success and type(decoded) == "table" then
            savedScripts = decoded
        end
    end
end

local function saveScriptsData()
    if writefile and HttpService then
        pcall(function()
            writefile(FILE_NAME, HttpService:JSONEncode(savedScripts))
        end)
    end
end

