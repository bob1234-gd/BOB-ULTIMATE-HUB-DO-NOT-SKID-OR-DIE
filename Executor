local function createRGBSlider(name, channel, positionY, defaultVal)
    local SliderBg = Instance.new("Frame")
    SliderBg.Size = UDim2.new(1, -140, 0, 30)
    SliderBg.Position = UDim2.new(0, 122, 0, positionY)
    SliderBg.BackgroundColor3 = Color3.fromRGB(32, 34, 37)
    SliderBg.Parent = RGBMainFrame

    local SBCorner = Instance.new("UICorner")
    SBCorner.CornerRadius = UDim.new(0, 4)
    SBCorner.Parent = SliderBg

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(0, 20, 1, 0)
    Title.Position = UDim2.new(0, 10, 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = name
    Title.TextColor3 = Color3.fromRGB(185, 187, 190)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 12
    Title.Parent = SliderBg

    local Track = Instance.new("Frame")
    Track.Size = UDim2.new(1, -75, 0, 4)
    Track.Position = UDim2.new(0, 35, 0.5, -2)
    Track.BackgroundColor3 = Color3.fromRGB(64, 68, 75)
    Track.BorderSizePixel = 0
    Track.Parent = SliderBg

    local Knob = Instance.new("TextButton")
    Knob.Size = UDim2.new(0, 12, 0, 12)
    Knob.Position = UDim2.new(defaultVal / 255, -6, 0.5, -6)
    Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Knob.Text = ""
    Knob.Parent = Track

    local KCorner = Instance.new("UICorner")
    KCorner.CornerRadius = UDim.new(1, 0)
    KCorner.Parent = Knob

    local ValueLabel = Instance.new("TextLabel")
    ValueLabel.Size = UDim2.new(0, 30, 1, 0)
    ValueLabel.Position = UDim2.new(1, -35, 0, 0)
    ValueLabel.BackgroundTransparency = 1
    ValueLabel.Text = tostring(defaultVal)
    ValueLabel.TextColor3 = Color3.fromRGB(220, 221, 222)
    ValueLabel.Font = Enum.Font.GothamMedium
    ValueLabel.TextSize = 11
    ValueLabel.Parent = SliderBg

    local dragging = false
    Knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local relativeX = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
            Knob.Position = UDim2.new(relativeX, -6, 0.5, -6)
            local calculatedVal = math.round(relativeX * 255)
            ValueLabel.Text = tostring(calculatedVal)
            if channel == "R" then rVal = calculatedVal
            elseif channel == "G" then gVal = calculatedVal
            elseif channel == "B" then bVal = calculatedVal end
            updateLiveRGB()
        end
    end)
end

createRGBSlider("R", "R", 15, rVal)
createRGBSlider("G", "G", 50, gVal)
createRGBSlider("B", "B", 85, bVal)

ApplyRGBBtn.MouseButton1Click:Connect(function()
    stopRainbow()
    updateTheme(Color3.fromRGB(rVal, gVal, bVal))
    ShowNotification("RGB Engine", "Applied custom theme setup color layouts!")
end)

