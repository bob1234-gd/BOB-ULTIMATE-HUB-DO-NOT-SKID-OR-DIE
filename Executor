-- Combined Feed Rendering Handler
local function renderFeed()
    for _, child in ipairs(ScriptsFeedContainer:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    local function createRowItem(scriptData, isDeletable, indexInTable)
        local ItemFrame = Instance.new("Frame")
        ItemFrame.Size = UDim2.new(1, 0, 0, 44)
        ItemFrame.BackgroundColor3 = Color3.fromRGB(47, 49, 54)
        ItemFrame.Parent = ScriptsFeedContainer

        local IFCorner = Instance.new("UICorner")
        IFCorner.CornerRadius = UDim.new(0, 4)
        IFCorner.Parent = ItemFrame

        local ScriptTitle = Instance.new("TextLabel")
        ScriptTitle.Size = UDim2.new(1, -180, 1, 0)
        ScriptTitle.Position = UDim2.new(0, 12, 0, 0)
        ScriptTitle.BackgroundTransparency = 1
        ScriptTitle.Font = Enum.Font.GothamBold
        ScriptTitle.TextSize = 13
        ScriptTitle.TextXAlignment = Enum.TextXAlignment.Left
        ScriptTitle.Parent = ItemFrame

        -- Styling differences between Community scripts and personal scripts
        if isDeletable then
            ScriptTitle.Text = scriptData.Name
            ScriptTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            ScriptTitle.Text = scriptData.Name .. " [Community]"
            ScriptTitle.TextColor3 = Color3.fromRGB(150, 200, 255) -- Distinct coloring for locked entries
        end

        -- Execute Button Configuration
        local ExecActionBtn = Instance.new("TextButton")
        ExecActionBtn.BackgroundColor3 = Color3.fromRGB(67, 181, 129)
        ExecActionBtn.Text = "Execute"
        ExecActionBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        ExecActionBtn.Font = Enum.Font.GothamBold
        ExecActionBtn.TextSize = 11
        ExecActionBtn.Parent = ItemFrame

        local EACorner = Instance.new("UICorner")
        EACorner.CornerRadius = UDim.new(0, 4)
        EACorner.Parent = ExecActionBtn

        if isDeletable then
            -- Standard item placement with working delete button
            ExecActionBtn.Size = UDim2.new(0, 70, 0, 26)
            ExecActionBtn.Position = UDim2.new(1, -165, 0.5, -13)

            local DeleteActionBtn = Instance.new("TextButton")
            DeleteActionBtn.Size = UDim2.new(0, 70, 0, 26)
            DeleteActionBtn.Position = UDim2.new(1, -85, 0.5, -13)
            DeleteActionBtn.BackgroundColor3 = Color3.fromRGB(240, 71, 71)
            DeleteActionBtn.Text = "Delete"
            DeleteActionBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            DeleteActionBtn.Font = Enum.Font.GothamBold
            DeleteActionBtn.TextSize = 11
            DeleteActionBtn.Parent = ItemFrame

            local DACorner = Instance.new("UICorner")
            DACorner.CornerRadius = UDim.new(0, 4)
            DACorner.Parent = DeleteActionBtn

            DeleteActionBtn.MouseButton1Click:Connect(function()
                table.remove(savedScripts, indexInTable)
                saveScriptsData()
                renderFeed()
                ShowNotification("Database Notice", "Deleted script profile.")
            end)
        else
            -- Community item structure: spans wider and drops the delete container completely
            ExecActionBtn.Size = UDim2.new(0, 85, 0, 26)
            ExecActionBtn.Position = UDim2.new(1, -100, 0.5, -13)
        end

        ExecActionBtn.MouseButton1Click:Connect(function()
            local executed, err = pcall(function()
                local func = loadstring(scriptData.Source)
                if func then task.spawn(func) else error(err) end
            end)
            if executed then
                ShowNotification("Scripts Core", "Executed: " .. scriptData.Name)
            else
                ShowNotification("Run Failure", "Failed script compilation.")
            end
        end)
    end

    -- First render un-deletable core elements
    for idx, data in ipairs(defaultScripts) do
        createRowItem(data, false, idx)
    end

    -- Next render modifiable configuration profile elements
    for idx, data in ipairs(savedScripts) do
        createRowItem(data, true, idx)
    end
end

SubmitPostBtn.MouseButton1Click:Connect(function()
    local targetName = NameInputBox.Text
    local targetSource = SourceInputBox.Text

    if string.gsub(targetName, " ", "") ~= "" and string.gsub(targetSource, " ", "") ~= "" then
        table.insert(savedScripts, 1, {Name = targetName, Source = targetSource})
        saveScriptsData()
        renderFeed()
        
        NameInputBox.Text = ""
        SourceInputBox.Text = ""
        ShowNotification("Success", "Script saved to local device profile cache!")
    else
        ShowNotification("Form Warning", "Fields cannot be processed empty.")
    end
end)

