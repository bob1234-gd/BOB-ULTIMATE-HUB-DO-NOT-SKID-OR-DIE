local function createThemeControl(themeName, color, isRainbowPreset)
    local ThemeFrame = Instance.new("Frame")
    ThemeFrame.Size = UDim2.new(1, 0, 0, 40)
    ThemeFrame.BackgroundColor3 = Color3.fromRGB(47, 49, 54)
    ThemeFrame.Parent = tabs["Settings"].Container

    local TFCorner = Instance.new("UICorner")
    TFCorner.CornerRadius = UDim.new(0, 4)
    ThemeFrame.Parent = tabs["Settings"].Container

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0, 150, 1, 0)
    Label.Position = UDim2.new(0, 12, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = themeName
    Label.TextColor3 = Color3.fromRGB(220, 221, 222)
    Label.Font = Enum.Font.GothamMedium
    Label.TextSize = 13
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = ThemeFrame

    local Preview = Instance.new("Frame")
    Preview.Name = "StaticColorPreview"
    Preview.Size = UDim2.new(0, 22, 0, 22)
    Preview.Position = UDim2.new(1, -110, 0.5, -11)

    if isRainbowPreset then
        Preview.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        local UIGradient = Instance.new("UIGradient")
        UIGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
            ColorSequenceKeypoint.new(0.4, Color3.fromRGB(0, 255, 0)),
            ColorSequenceKeypoint.new(0.8, Color3.fromRGB(0, 0, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
        })
        UIGradient.Parent = Preview
    else
        Preview.BackgroundColor3 = color
    end

    Preview.Parent = ThemeFrame

    local PCorner = Instance.new("UICorner")
    PCorner.CornerRadius = UDim.new(0, 4)
    PCorner.Parent = Preview

    local ApplyBtn = Instance.new("TextButton")
    ApplyBtn.Size = UDim2.new(0, 70, 0, 26)
    ApplyBtn.Position = UDim2.new(1, -80, 0.5, -13)
    ApplyBtn.BackgroundColor3 = Color3.fromRGB(67, 181, 129)
    ApplyBtn.Text = "Apply"
    ApplyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    ApplyBtn.Font = Enum.Font.GothamBold
    ApplyBtn.TextSize = 11
    ApplyBtn.Parent = ThemeFrame

    local ABCorner = Instance.new("UICorner")
    ABCorner.CornerRadius = UDim.new(0, 4)
    ABCorner.Parent = ApplyBtn

    ApplyBtn.MouseButton1Click:Connect(function()
        if isRainbowPreset then
            startRainbow()
            ShowNotification("Theme Config", "Dynamic Rainbow style preset active!")
        else
            stopRainbow()
            updateTheme(color)
            ShowNotification("Theme Config", "Custom theme profile adjusted successfully!")
        end
    end)
end

