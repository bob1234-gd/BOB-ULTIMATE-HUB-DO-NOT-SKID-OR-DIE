-- =============================================================================
local function updateTheme(newColor)
    currentThemeColor = newColor
    for _, element in ipairs(registeredElements) do
        if element.Parent and (element.Name == "TopBarAccent" or element.Name == "AccentLine") then
            element.BackgroundColor3 = newColor
        elseif element:IsA("TextLabel") and element.Name == "TabButtonText" and element.Parent.Name == "ActiveTab" then
            element.TextColor3 = newColor
        end
    end
end

local function stopRainbow()
    if rainbowConnection then
        rainbowConnection:Disconnect()
        rainbowConnection = nil
    end
end

local function startRainbow()
    stopRainbow()
    rainbowConnection = RunService.RenderStepped:Connect(function()
        local hue = (tick() % 4) / 4
        local color = Color3.fromHSV(hue, 1, 1)
        updateTheme(color)
    end)
end

ScreenGui.Destroying:Connect(stopRainbow)

